// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role{
  Author
  Buyer
  Publisher
}

model User {
  id Int @default(autoincrement()) @id
  f_name String
  l_name String
  username String @unique
  password String
  email String @unique
  country String?
  role Role @default(Author)
  walletId String @unique

  books Book[]

  authoredAgreements Agreement[] @relation("AuthorAgreements")
  publishedAgreements Agreement[] @relation("PublisherAgreements")

  signatures Signature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Book {
  id Int @default(autoincrement()) @id
  name String
  description String?
  summary String?
  userId Int
  user User @relation(fields: [userId], references: [id])
  documents Document[]
  agreements Agreement[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id Int @default(autoincrement()) @id
  file_name String
  file_path String
  book_id Int
  book Book @relation(fields: [book_id], references: [id])
  agreements Agreement[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AgreementStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

model Agreement {
  id Int @id @default(autoincrement())

  title String
  description String?

  authorId Int
  publisherId Int

  author User @relation("AuthorAgreements", fields: [authorId], references: [id])
  publisher User @relation("PublisherAgreements", fields: [publisherId], references: [id])

  bookId Int
  book Book @relation(fields: [bookId], references: [id])

  documentId Int?
  document Document? @relation(fields: [documentId], references: [id])

  status AgreementStatus @default(DRAFT)

  contractData Json?   // agreement content
  blockchainAddress String? // future

  pdfPath String?

  signatures Signature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Signature {
  id Int @id @default(autoincrement())

  agreementId Int
  userId Int

  agreement Agreement @relation(fields: [agreementId], references: [id])
  user User @relation(fields: [userId], references: [id])

  signed Boolean @default(false)
  signedAt DateTime?

  createdAt DateTime @default(now())
}